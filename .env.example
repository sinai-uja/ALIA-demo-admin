# .env.example — copia este fichero a .env y rellena los valores reales.
#
#     cp .env.example .env
#
# Las variables marcadas como [MANDATORY] son leídas por backend.config.Settings
# sin default: el backend falla al arrancar con un ValidationError claro si
# falta cualquiera. El resto son opcionales y caen en defaults razonables.
#
# Los modelos MrBERT y cross-encoder son internos UJA: contacta con el
# equipo del proyecto para obtenerlos.

# ── [MANDATORY] LLM principal ─────────────────────────────────────────────
# URL del servidor llama.cpp (u otro runtime con API compatible OpenAI).
ALIA_LLM_URL=http://localhost:12021/v1
# Identificador del modelo cargado. En el setup UJA es la ruta absoluta al
# .gguf; con otros runtimes basta con el nombre del modelo.
ALIA_LLM_MODEL=/ruta/al/modelo.gguf

# ── [MANDATORY] Embeddings y reranker ─────────────────────────────────────
# Ruta local a MrBERT (modelo interno UJA).
EMBEDDING_MODEL_PATH=/ruta/a/MrBERT
# Ruta local al cross-encoder de reranking (modelo interno UJA).
TRAMITES_RERANKER_PATH=/ruta/a/cross-encoder-ms-marco-MiniLM-L6

# ── [Recomendado] Autenticación del backend ───────────────────────────────
# Token compartido para autenticar peticiones al backend (HMAC). Vacío en
# modo dev acepta cualquier petición; en cualquier despliegue real, ponlo.
ALIA_API_KEY=cambia-este-token

# ── [Opcional] LLM secundario (solo tab Comparador) ───────────────────────
# Sin estas dos variables, /comparador/stream responde 503.
#ALIA_LLM_URL_2=http://localhost:12022/v1
#ALIA_LLM_MODEL_2=/ruta/al/segundo-modelo.gguf

# ── [Opcional] Embeddings device ──────────────────────────────────────────
# cpu | mps (Apple Silicon) | cuda. Default: cpu
EMBEDDING_DEVICE=cpu

# ── [Opcional] Almacenamiento vectorial ───────────────────────────────────
# Default: ./chroma_db
CHROMA_PERSIST_DIR=./chroma_db

# ── [Opcional] RAG Trámites (defaults razonables) ─────────────────────────
TRAMITES_DATA_PATH=./data/export.json
TRAMITES_CHROMA_COLLECTION=tramites_municipales
TRAMITES_TOP_K=5
TRAMITES_TOP_K_RERANK=3

# ── [Opcional] MLflow (requiere docker compose up o instancia local) ──────
# Sin esta variable, el tracking queda desactivado y el backend arranca igual.
#MLFLOW_TRACKING_URI=http://localhost:5001
# Usado por el frontend para exponer el dashboard MLflow vía proxy.
#MLFLOW_EXTERNAL_URL=/mlflow-ui

# ── [Solo Docker] Ruta host a los modelos internos UJA ────────────────────
# Directorio del host que contiene los subdirectorios MrBERT/ y
# cross-encoder-ms-marco-MiniLM-L6/. Usado por docker-compose.yml para
# montarlos como volúmenes read-only en el contenedor backend.
# Si NO usas Docker, ignora esta variable y usa EMBEDDING_MODEL_PATH /
# TRAMITES_RERANKER_PATH apuntando a rutas locales.
MODELS_HOST_PATH=/ruta/a/tus/modelos

# ── [Opcional] Feedback humano (Fase 7) ───────────────────────────────────
# Pon "false" para desactivar /feedback y /feedback/expectation
# y ocultar los thumbs up/down del frontend. Default: true
FEEDBACK_ENABLED=true

# ── [Opcional] Prompt Registry de MLflow (Fase 13) ────────────────────────
# Externaliza los prompts de chat (Trámites, Comparador A, RAG docs) al
# Prompt Registry de MLflow para que se editen sin redeploy. Si MLflow no
# responde, el provider cae silenciosamente al prompt empaquetado y emite
# log WARNING.
# Pon "false" para servir SIEMPRE desde el empaquetado (rollback rápido sin
# redeploy). Default: true
PROMPT_REGISTRY_ENABLED=true
# Alias por defecto a resolver en `prompts:/<name>@<alias>` (lo que el
# operador mueve en MLflow UI). Valores típicos: staging, production.
# Default: production
PROMPT_REGISTRY_ALIAS=production
# TTL en segundos de la caché in-memory del PromptProvider. Cuanto más
# bajo, más rápido se propaga un cambio de alias en MLflow al runtime,
# pero más carga sobre el servidor MLflow. Default: 300 (5 minutos)
PROMPT_REGISTRY_CACHE_TTL_SECONDS=300

# ── [Opcional] Logging ────────────────────────────────────────────────────
# Nivel de log del backend. Aplicado en backend/main.py vía
# logging.basicConfig. Valores: DEBUG, INFO, WARNING, ERROR. Default: INFO
LOG_LEVEL=INFO

# ── [Opcional] Red (frontend) ─────────────────────────────────────────────
# URL del backend desde el frontend. En setup nativo: localhost:8001.
# En docker-compose se sobrescribe a http://backend:8000 (red interna).
BACKEND_URL=http://localhost:8001
GRADIO_SERVER_PORT=7861

# ── [Opcional] Frontend de evaluación pública (frontend/eval_app.py) ──────
# Entrypoint paralelo al frontend principal con solo la tab Trámites,
# pensado para evaluadores externos. En local: `python frontend/eval_app.py`
# escucha en este puerto. En docker-compose el host se publica como:
# base 7863, dev 7864, pre 7865, pro 7863. URL abierta sin auth adicional.
GRADIO_EVAL_SERVER_PORT=7861

# ── [Opcional] Evaluación con LLM-as-a-judge (scripts/run_evaluation) ─────
# Solo se necesita si invocas scripts/run_evaluation.py con un juez OpenAI.
#OPENAI_API_KEY=
